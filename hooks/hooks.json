{
  "description": "Vanta workspace hooks: reference-staleness check on session start, destructive-operation guard before Bash",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/auto-sync.py\" || python \"${CLAUDE_PLUGIN_ROOT}/hooks/auto-sync.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/block-destructive.py\" || python \"${CLAUDE_PLUGIN_ROOT}/hooks/block-destructive.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
